# IMS environment — copy to `.env` and tweak for local dev.
# Required by NFR-4.2 (00-master-prd §5.4): config via env vars with sane defaults.

# HTTP server bind address (default :8080 if unset).
IMS_HTTP_ADDR=:8080

# Postgres / TimescaleDB. Same DSN — Timescale is a Postgres extension.
DATABASE_URL=postgres://ims:ims@localhost:5432/ims?sslmode=disable

# MongoDB.
MONGO_URI=mongodb://ims:ims@localhost:27017/ims?authSource=admin

# Redis.
REDIS_ADDR=localhost:6379
