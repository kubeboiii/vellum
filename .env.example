# Vellum environment — copy to `.env` and tweak for local dev.
# Required by NFR-4.2 (00-master-prd §5.4): config via env vars
# with sane defaults. Every variable here has a default in
# backend/cmd/vellum/main.go; the values shown ARE the defaults.

# ─── Servers ────────────────────────────────────────────────────────
VELLUM_HTTP_ADDR=:8080                  # HTTP / Gin bind address
VELLUM_GRPC_ADDR=:9090                  # gRPC bind address (FR-1.2)
VELLUM_CORS_ORIGINS=http://localhost:3000   # comma-sep allow-list for the dashboard

# ─── Postgres / TimescaleDB ─────────────────────────────────────────
# Same DSN — Timescale is a Postgres extension on the same instance.
DATABASE_URL=postgres://vellum:vellum@localhost:5432/vellum?sslmode=disable

# ─── MongoDB ────────────────────────────────────────────────────────
MONGO_URI=mongodb://vellum:vellum@localhost:27017/vellum?authSource=admin
MONGO_DATABASE=vellum

# ─── Redis ──────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379

# ─── Ingestion pipeline (Phase 2 + 3) ──────────────────────────────
VELLUM_QUEUE_CAPACITY=50000             # bounded channel; 503 when full (FR-1.5)
VELLUM_WORKER_COUNT=16                  # goroutines draining the channel
VELLUM_RATE_LIMIT_RPS=1000              # per-source rate limit (FR-1.6)
VELLUM_RATE_LIMIT_BURST=2000

# ─── Debouncer (Phase 3) ────────────────────────────────────────────
VELLUM_DEBOUNCE_WINDOW_SECONDS=10       # FR-3.1
VELLUM_DEBOUNCE_MAX_SIGNALS=100         # FR-3.1 — also drives ceil(N/cap) work_items

# ─── Observability (Phase 2 + 4) ───────────────────────────────────
VELLUM_METRICS_INTERVAL=5s              # FR-8.2 — backend stdout ticker cadence
VELLUM_DEP_PING_TIMEOUT=500ms           # /health pings each dep with this timeout
VELLUM_SHUTDOWN_TIMEOUT=30s             # graceful-drain deadline on SIGTERM (NFR-2.4)

# ─── Alerters (Phase 4) ─────────────────────────────────────────────
VELLUM_ALERTER_TIMEOUT=2s               # cap per alerter send
# Optional; if empty, Slack alerter logs to console instead.
SLACK_WEBHOOK_URL=

# ─── Integration test (Phase 6) ─────────────────────────────────────
# Used by backend/internal/e2e_integration_test.go to point at a
# non-default backend address (default http://localhost:8080).
# VELLUM_BASE_URL=http://localhost:8080
